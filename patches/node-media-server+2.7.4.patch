   return shv === ohv;
 }
 
+function getFFmpegUrl() {
+  return 'https://johnvansickle.com/ffmpeg/';
+}
+
+/** @param {string} ffmpegPath */
+function getFFmpegVersion(ffmpegPath) {
+  return new Promise((resolve) => {
+    const ff = spawn(ffmpegPath, ['-version']);
+    let out = '';
+    ff.stdout.on('data', (d) => {
+      out += d.toString();
+    });
+    ff.stderr.on('data', (d) => {
+      out += d.toString();
+    });
+    ff.on('close', () => {
+      const m = out.match(/ffmpeg version ([^\s,]+)/i);
+      resolve(m ? m[1] : '');
+    });
+    ff.on('error', () => {
+      resolve('');
+    });
+  });
+}
+
 module.exports = {
   generateNewSessionID,
   verifyAuth,
   genRandomName,
+  getFFmpegVersion,
+  getFFmpegUrl,
 };
