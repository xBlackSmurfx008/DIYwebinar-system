{
  "name": "obs-events-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev:web": "npm -w apps/web run dev",
    "dev:rtmp": "npm -w services/rtmp run dev",
    "db:generate": "npm -w @platform/db run generate",
    "db:migrate": "npm -w @platform/db run migrate",
    "build": "npm run db:generate && npm -w apps/web run build && npm -w services/rtmp run build",
    "start": "npm -w apps/web run start"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "typescript": "^5.6.3"
  }
}
