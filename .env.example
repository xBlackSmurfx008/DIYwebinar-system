# === Neon PostgreSQL ===
# Get these from https://console.neon.tech after creating a project
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/events?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/events?sslmode=require

# === NextAuth ===
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.vercel.app

# === RTMP Streaming Server ===
# URL where OBS connects (your Railway/Fly.io RTMP server)
RTMP_URL=rtmp://your-rtmp-server.railway.app:1935/live
# URL where browsers fetch HLS segments
HLS_HOST=https://your-rtmp-server.railway.app:8000

# === Optional ===
OPENAI_API_KEY=
