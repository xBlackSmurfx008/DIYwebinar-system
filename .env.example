# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/events?schema=public

# NextAuth (required for auth to work)
NEXTAUTH_SECRET=change-me-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# RTMP / HLS (used by OBS page and viewer)
RTMP_HOST=localhost
RTMP_PORT=1935
RTMP_HTTP_PORT=8000

# HLS host for audience viewer (override if behind a reverse proxy / CDN)
# HLS_HOST=http://localhost:8000

# OpenAI (optional, for AI features)
# OPENAI_API_KEY=sk-...
